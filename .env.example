# ══════════════════════════════════════════════════════════════════
#  FINDIR — Environment variables
#  Скопируйте в .env и заполните реальными значениями
#  НИКОГДА не коммитьте .env в git!
# ══════════════════════════════════════════════════════════════════

# ── Приложение ────────────────────────────────────────────────────
APP_ENV=production          # local | production
APP_DEBUG=false
APP_KEY=                    # php artisan key:generate
APP_URL=https://app.findir.ru

# ── Nginx порты ───────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Центральный домен (stancl/tenancy) ────────────────────────────
# Запросы на этот домен НЕ идут через tenant middleware
CENTRAL_DOMAIN=findir.ru

# ── PHP ───────────────────────────────────────────────────────────
PHP_VERSION=8.3

# ── MySQL ─────────────────────────────────────────────────────────
DB_DATABASE=findir_central
DB_USERNAME=findir
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_EXTERNAL_PORT=3306       # убрать или сменить порт в продакшне!

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_MAXMEMORY=256mb

# ── Mail (продакшн — реальный SMTP) ──────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=noreply@findir.ru
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@findir.ru
MAIL_FROM_NAME=FINDIR
