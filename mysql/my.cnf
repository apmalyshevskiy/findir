[mysqld]
# ── Кодировка ─────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── InnoDB (производительность) ───────────────────────────────────
innodb_buffer_pool_size        = 512M      # 50-70% RAM сервера
innodb_buffer_pool_instances   = 2
innodb_log_file_size           = 128M
innodb_flush_log_at_trx_commit = 2         # баланс надёжность/скорость
innodb_flush_method            = O_DIRECT
innodb_file_per_table          = ON

# ── Соединения ────────────────────────────────────────────────────
max_connections         = 200
max_connect_errors      = 10000
wait_timeout            = 600
interactive_timeout     = 600

# ── Query cache (отключён в MySQL 8) ─────────────────────────────
# query_cache_type = 0

# ── Slow query log ────────────────────────────────────────────────
slow_query_log          = 1
slow_query_log_file     = /var/lib/mysql/slow.log
long_query_time         = 2
log_queries_not_using_indexes = 1

# ── Бинарный лог (для репликации / point-in-time recovery) ───────
log_bin                 = /var/lib/mysql/mysql-bin
binlog_format           = ROW
expire_logs_days        = 7
max_binlog_size         = 100M

# ── Безопасность ──────────────────────────────────────────────────
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
